{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^bun$": "<rootDir>/../__mocks__/bun.ts"
  },
  "setupFiles": ["<rootDir>/jest-setup.js"],
  "maxWorkers": 1,
  "verbose": true
}
